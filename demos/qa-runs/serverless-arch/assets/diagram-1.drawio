<mxfile host="app.diagrams.net" type="device">
  <diagram id="arch1" name="Serverless Image Pipeline">
    <mxGraphModel dx="1200" dy="700" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="940" pageHeight="540" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- ===== Ingestion row (y=190) : Users -> S3 -> Lambda ===== -->
        <mxCell id="users" value="Users" style="sketch=0;resIcon=mxgraph.aws4.users;shape=mxgraph.aws4.resourceIcon;fillColor=#232F3E;strokeColor=none;verticalLabelPosition=bottom;verticalAlign=top;fontColor=#FFFFFF;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="60" y="200" width="78" height="78" as="geometry" />
        </mxCell>

        <mxCell id="s3" value="Amazon S3&#10;(uploads)" style="sketch=0;resIcon=mxgraph.aws4.s3;shape=mxgraph.aws4.resourceIcon;fillColor=#7AA116;strokeColor=none;verticalLabelPosition=bottom;verticalAlign=top;fontColor=#FFFFFF;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="300" y="200" width="78" height="78" as="geometry" />
        </mxCell>

        <mxCell id="lambda" value="AWS Lambda&#10;(processor)" style="sketch=0;resIcon=mxgraph.aws4.lambda;shape=mxgraph.aws4.resourceIcon;fillColor=#ED7100;strokeColor=none;verticalLabelPosition=bottom;verticalAlign=top;fontColor=#FFFFFF;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="540" y="200" width="78" height="78" as="geometry" />
        </mxCell>

        <!-- ===== Lambda branches : Rekognition (up), DynamoDB (down) ===== -->
        <mxCell id="rek" value="Amazon Rekognition" style="sketch=0;resIcon=mxgraph.aws4.rekognition;shape=mxgraph.aws4.resourceIcon;fillColor=#01A88D;strokeColor=none;verticalLabelPosition=bottom;verticalAlign=top;fontColor=#FFFFFF;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="780" y="70" width="78" height="78" as="geometry" />
        </mxCell>

        <mxCell id="ddb" value="Amazon DynamoDB&#10;(metadata)" style="sketch=0;resIcon=mxgraph.aws4.dynamodb;shape=mxgraph.aws4.resourceIcon;fillColor=#2E27AD;strokeColor=none;verticalLabelPosition=bottom;verticalAlign=top;fontColor=#FFFFFF;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="780" y="330" width="78" height="78" as="geometry" />
        </mxCell>

        <!-- ===== Delivery lane (bottom) : S3 -> CloudFront -> Users ===== -->
        <mxCell id="cf" value="Amazon CloudFront&#10;(edge delivery)" style="sketch=0;resIcon=mxgraph.aws4.cloudfront;shape=mxgraph.aws4.resourceIcon;fillColor=#8C4FFF;strokeColor=none;verticalLabelPosition=bottom;verticalAlign=top;fontColor=#FFFFFF;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="300" y="420" width="78" height="78" as="geometry" />
        </mxCell>

        <!-- ===== Edges ===== -->
        <mxCell id="e1" value="upload" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#8B5CF6;strokeWidth=2.5;fontColor=#D8C9FF;fontSize=12;fontStyle=1;endArrow=block;endFill=1;labelBackgroundColor=#0A0A0A;" edge="1" parent="1" source="users" target="s3">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e2" value="S3 event" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#8B5CF6;strokeWidth=2.5;fontColor=#D8C9FF;fontSize=12;fontStyle=1;endArrow=block;endFill=1;labelBackgroundColor=#0A0A0A;" edge="1" parent="1" source="s3" target="lambda">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e3" value="analyze" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#D946EF;strokeWidth=2.5;fontColor=#F4C6FF;fontSize=12;fontStyle=1;endArrow=block;endFill=1;labelBackgroundColor=#0A0A0A;exitX=1;exitY=0.25;exitDx=0;exitDy=0;" edge="1" parent="1" source="lambda" target="rek">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e4" value="write labels" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#D946EF;strokeWidth=2.5;fontColor=#F4C6FF;fontSize=12;fontStyle=1;endArrow=block;endFill=1;labelBackgroundColor=#0A0A0A;exitX=1;exitY=0.75;exitDx=0;exitDy=0;" edge="1" parent="1" source="lambda" target="ddb">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e5" value="origin fetch" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#8B5CF6;strokeWidth=2.5;fontColor=#D8C9FF;fontSize=12;fontStyle=1;endArrow=block;endFill=1;dashed=1;labelBackgroundColor=#0A0A0A;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="s3" target="cf">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e6" value="deliver" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#FF9900;strokeWidth=2.5;fontColor=#FFD79A;fontSize=12;fontStyle=1;endArrow=block;endFill=1;labelBackgroundColor=#0A0A0A;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=0.5;entryY=1;entryDx=0;entryDy=0;" edge="1" parent="1" source="cf" target="users">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
