<mxfile host="app.diagrams.net" type="device">
  <diagram id="flow1" name="Upload Decision Path">
    <mxGraphModel dx="1200" dy="800" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="900" pageHeight="620" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Start -->
        <mxCell id="start" value="Image uploaded" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1A1033;strokeColor=#8B5CF6;strokeWidth=2;fontColor=#FFFFFF;fontSize=14;fontStyle=1;shadow=0;" vertex="1" parent="1">
          <mxGeometry x="360" y="20" width="180" height="50" as="geometry" />
        </mxCell>

        <!-- Decision 1: valid? -->
        <mxCell id="d1" value="Valid type &amp; size?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#241544;strokeColor=#D946EF;strokeWidth=2;fontColor=#FFFFFF;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="355" y="120" width="190" height="100" as="geometry" />
        </mxCell>

        <!-- Reject -->
        <mxCell id="reject" value="Reject upload&#10;return error" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#2A0E1A;strokeColor=#F472B6;strokeWidth=2;fontColor=#FFD6E8;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="660" y="135" width="170" height="70" as="geometry" />
        </mxCell>

        <!-- Store + analyze -->
        <mxCell id="store" value="Store original&#10;&amp; trigger analysis" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1A1033;strokeColor=#8B5CF6;strokeWidth=2;fontColor=#FFFFFF;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="360" y="280" width="180" height="60" as="geometry" />
        </mxCell>

        <!-- Rekognition -->
        <mxCell id="rek" value="Rekognition:&#10;labels + moderation" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0A2E29;strokeColor=#34D399;strokeWidth=2;fontColor=#C8FFEF;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="360" y="380" width="180" height="60" as="geometry" />
        </mxCell>

        <!-- Decision 2: flagged? -->
        <mxCell id="d2" value="Content flagged?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#241544;strokeColor=#D946EF;strokeWidth=2;fontColor=#FFFFFF;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="355" y="475" width="190" height="100" as="geometry" />
        </mxCell>

        <!-- Quarantine -->
        <mxCell id="quar" value="Quarantine&#10;for review" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#2A1F08;strokeColor=#FF9900;strokeWidth=2;fontColor=#FFE3B3;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="660" y="490" width="170" height="70" as="geometry" />
        </mxCell>

        <!-- Publish -->
        <mxCell id="pub" value="Publish to CDN" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#150A2E;strokeColor=#8B5CF6;strokeWidth=2.5;fontColor=#FFFFFF;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="70" y="490" width="170" height="70" as="geometry" />
        </mxCell>

        <!-- Edges -->
        <mxCell id="f0" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#8B5CF6;strokeWidth=2.5;endArrow=block;endFill=1;labelBackgroundColor=#0A0A0A;" edge="1" parent="1" source="start" target="d1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="f1" value="no" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#F472B6;strokeWidth=2.5;fontColor=#FFD6E8;fontSize=12;endArrow=block;endFill=1;labelBackgroundColor=#0A0A0A;" edge="1" parent="1" source="d1" target="reject"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="f2" value="yes" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#8B5CF6;strokeWidth=2.5;fontColor=#D8C9FF;fontSize=12;endArrow=block;endFill=1;labelBackgroundColor=#0A0A0A;" edge="1" parent="1" source="d1" target="store"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="f3" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#8B5CF6;strokeWidth=2.5;endArrow=block;endFill=1;labelBackgroundColor=#0A0A0A;" edge="1" parent="1" source="store" target="rek"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="f4" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#8B5CF6;strokeWidth=2.5;endArrow=block;endFill=1;labelBackgroundColor=#0A0A0A;" edge="1" parent="1" source="rek" target="d2"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="f5" value="yes" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#FF9900;strokeWidth=2.5;fontColor=#FFE3B3;fontSize=12;endArrow=block;endFill=1;labelBackgroundColor=#0A0A0A;" edge="1" parent="1" source="d2" target="quar"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="f6" value="no" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#34D399;strokeWidth=2.5;fontColor=#C8FFEF;fontSize=12;endArrow=block;endFill=1;labelBackgroundColor=#0A0A0A;" edge="1" parent="1" source="d2" target="pub"><mxGeometry relative="1" as="geometry" /></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
